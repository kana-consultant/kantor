# Database
POSTGRES_DB=internal_platform
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# Backend
APP_ENV=development
PORT=8080
# Used when running backend directly on the host. Docker Compose overrides this
# to use the PostgreSQL service hostname `db`.
DATABASE_URL=postgres://dev:dev@localhost:5432/internal_platform?sslmode=disable
JWT_SECRET=change-me
DATA_ENCRYPTION_KEY=change-me-too
# Used when running backend directly on the host. Docker Compose overrides this
# to use the writable container path `/app/data/uploads`.
UPLOADS_DIR=./uploads
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
CORS_ORIGINS=http://localhost:3000
SEED_SUPERADMIN_ENABLED=true
SEED_SUPERADMIN_EMAIL=superadmin@kantor.local
SEED_SUPERADMIN_PASSWORD=Password123!
SEED_SUPERADMIN_FULL_NAME=Seeded Super Admin
SEED_DEMO_USERS_ENABLED=true
SEED_STAFF_EMAIL=staff.ops@kantor.local
SEED_STAFF_PASSWORD=Password123!
SEED_STAFF_FULL_NAME=Operational Staff
SEED_STAFF_DEPARTMENT=engineering
SEED_STAFF_SKILLS=frontend,kanban
SEED_VIEWER_EMAIL=viewer.ops@kantor.local
SEED_VIEWER_PASSWORD=Password123!
SEED_VIEWER_FULL_NAME=Operational Viewer
SEED_VIEWER_DEPARTMENT=finance
SEED_VIEWER_SKILLS=qa,reporting
SEED_MARKETING_STAFF_EMAIL=staff.marketing@kantor.local
SEED_MARKETING_STAFF_PASSWORD=Password123!
SEED_MARKETING_STAFF_FULL_NAME=Marketing Staff
SEED_MARKETING_STAFF_DEPARTMENT=marketing
SEED_MARKETING_STAFF_SKILLS=copywriting,ads,crm
SEED_MARKETING_VIEWER_EMAIL=viewer.marketing@kantor.local
SEED_MARKETING_VIEWER_PASSWORD=Password123!
SEED_MARKETING_VIEWER_FULL_NAME=Marketing Viewer
SEED_MARKETING_VIEWER_DEPARTMENT=marketing
SEED_MARKETING_VIEWER_SKILLS=reporting

# Frontend
# Used when running the frontend directly with Vite. Docker Compose builds the
# frontend with `/api/v1` and proxies requests through nginx to the backend.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# WhatsApp (Unofficial)
WA_SESSION_PATH=./wa-sessions
WA_REMINDER_CRON=0 8 * * 1-5

# Chrome Extension
CHROME_EXT_API_KEY=change-me
